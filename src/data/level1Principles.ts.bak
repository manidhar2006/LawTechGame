export const LEVEL1_CARD_MAP = new Map(LEVEL1_PRINCIPLE_CARDS.map((card) => [card.id, card]));

export function getLevel1CardById(cardId: string | null | undefined) {
  if (!cardId) return null;
  return LEVEL1_CARD_MAP.get(cardId) ?? null;
}
